{
    "openapi": "3.0.3",
    "info": {
        "title": "Escrow Integration API",
        "version": "v1"
    },
    "paths": {
        "/api/v1/agreements/": {
            "post": {
                "operationId": "createAgreement",
                "description": "Create an immutable agreement through a scoped organization API key.",
                "parameters": [
                    {
                        "in": "header",
                        "name": "Authorization",
                        "schema": {
                            "type": "string"
                        },
                        "description": "Bearer esk_<prefix>_<secret>",
                        "required": true
                    },
                    {
                        "in": "header",
                        "name": "Idempotency-Key",
                        "schema": {
                            "type": "string"
                        },
                        "description": "Unique key for one organization agreement creation command.",
                        "required": true
                    }
                ],
                "tags": [
                    "agreements"
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/AgreementCreate"
                            }
                        },
                        "application/x-www-form-urlencoded": {
                            "schema": {
                                "$ref": "#/components/schemas/AgreementCreate"
                            }
                        },
                        "multipart/form-data": {
                            "schema": {
                                "$ref": "#/components/schemas/AgreementCreate"
                            }
                        }
                    },
                    "required": true
                },
                "security": [
                    {
                        "ApiKeyAuth": []
                    }
                ],
                "responses": {
                    "201": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/AgreementCreationResponse"
                                }
                            }
                        },
                        "description": ""
                    }
                }
            }
        },
        "/api/v1/agreements/{agreement_id}/delivery/": {
            "post": {
                "operationId": "reportAgreementDelivery",
                "description": "Let the owning organization begin its customer's inspection window.",
                "parameters": [
                    {
                        "in": "header",
                        "name": "Authorization",
                        "schema": {
                            "type": "string"
                        },
                        "description": "Bearer organization API key with agreements:write.",
                        "required": true
                    },
                    {
                        "in": "header",
                        "name": "Idempotency-Key",
                        "schema": {
                            "type": "string"
                        },
                        "description": "Unique key for one delivery declaration.",
                        "required": true
                    },
                    {
                        "in": "path",
                        "name": "agreement_id",
                        "schema": {
                            "type": "string",
                            "format": "uuid"
                        },
                        "required": true
                    }
                ],
                "tags": [
                    "agreements"
                ],
                "security": [
                    {
                        "ApiKeyAuth": []
                    }
                ],
                "responses": {
                    "202": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/DeliveryReportResponse"
                                }
                            }
                        },
                        "description": ""
                    }
                }
            }
        },
        "/api/v1/checkout/{checkout_token}/": {
            "get": {
                "operationId": "getPublicCheckout",
                "description": "Return a bounded public snapshot for one opaque checkout capability.",
                "parameters": [
                    {
                        "in": "path",
                        "name": "checkout_token",
                        "schema": {
                            "type": "string"
                        },
                        "required": true
                    }
                ],
                "tags": [
                    "checkout"
                ],
                "responses": {
                    "200": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/PublicCheckoutResponse"
                                }
                            }
                        },
                        "description": ""
                    }
                }
            }
        },
        "/api/v1/checkout/{checkout_token}/delivery-acceptance/": {
            "post": {
                "operationId": "acceptCustomerDelivery",
                "description": "Asynchronously request release after a fresh customer email verification.",
                "parameters": [
                    {
                        "in": "path",
                        "name": "checkout_token",
                        "schema": {
                            "type": "string"
                        },
                        "required": true
                    }
                ],
                "tags": [
                    "checkout"
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/CustomerDeliveryAcceptance"
                            }
                        },
                        "application/x-www-form-urlencoded": {
                            "schema": {
                                "$ref": "#/components/schemas/CustomerDeliveryAcceptance"
                            }
                        },
                        "multipart/form-data": {
                            "schema": {
                                "$ref": "#/components/schemas/CustomerDeliveryAcceptance"
                            }
                        }
                    },
                    "required": true
                },
                "responses": {
                    "202": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/CustomerDeliveryAcceptanceResponse"
                                }
                            }
                        },
                        "description": ""
                    }
                }
            }
        },
        "/api/v1/checkout/{checkout_token}/delivery-acceptance/otp/": {
            "post": {
                "operationId": "requestCustomerDeliveryAcceptanceOtp",
                "description": "Email the customer a proof required before they can release held funds.",
                "parameters": [
                    {
                        "in": "path",
                        "name": "checkout_token",
                        "schema": {
                            "type": "string"
                        },
                        "required": true
                    }
                ],
                "tags": [
                    "checkout"
                ],
                "responses": {
                    "202": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/CustomerOtpRequestResponse"
                                }
                            }
                        },
                        "description": ""
                    }
                }
            }
        },
        "/api/v1/checkout/{checkout_token}/delivery-acceptance/otp/{challenge_id}/verify/": {
            "post": {
                "operationId": "verifyCustomerDeliveryAcceptanceOtp",
                "description": "Turn a valid emailed code into a short-lived one-time acceptance proof.",
                "parameters": [
                    {
                        "in": "path",
                        "name": "challenge_id",
                        "schema": {
                            "type": "string",
                            "format": "uuid"
                        },
                        "required": true
                    },
                    {
                        "in": "path",
                        "name": "checkout_token",
                        "schema": {
                            "type": "string"
                        },
                        "required": true
                    }
                ],
                "tags": [
                    "checkout"
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/CustomerOtpVerification"
                            }
                        },
                        "application/x-www-form-urlencoded": {
                            "schema": {
                                "$ref": "#/components/schemas/CustomerOtpVerification"
                            }
                        },
                        "multipart/form-data": {
                            "schema": {
                                "$ref": "#/components/schemas/CustomerOtpVerification"
                            }
                        }
                    },
                    "required": true
                },
                "responses": {
                    "200": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/CustomerOtpVerificationResponse"
                                }
                            }
                        },
                        "description": ""
                    }
                }
            }
        },
        "/api/v1/checkout/{checkout_token}/pix-charges/": {
            "post": {
                "operationId": "createSandboxPixCharge",
                "description": "Create/replay the only simulated PIX charge behind a checkout capability.",
                "parameters": [
                    {
                        "in": "header",
                        "name": "Idempotency-Key",
                        "schema": {
                            "type": "string"
                        },
                        "description": "Replay key for this public checkout PIX instruction.",
                        "required": true
                    },
                    {
                        "in": "path",
                        "name": "checkout_token",
                        "schema": {
                            "type": "string"
                        },
                        "required": true
                    }
                ],
                "tags": [
                    "checkout"
                ],
                "responses": {
                    "202": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/PublicSandboxPixChargeResponse"
                                }
                            }
                        },
                        "description": ""
                    }
                }
            }
        },
        "/api/v1/integrations/organization/": {
            "get": {
                "operationId": "getIntegrationOrganization",
                "description": "Example tenant-scoped API endpoint used to verify bearer-key contracts.",
                "parameters": [
                    {
                        "in": "header",
                        "name": "Authorization",
                        "schema": {
                            "type": "string"
                        },
                        "description": "Bearer esk_<prefix>_<secret>",
                        "required": true
                    }
                ],
                "tags": [
                    "integrations"
                ],
                "security": [
                    {
                        "ApiKeyAuth": []
                    }
                ],
                "responses": {
                    "200": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/IntegrationOrganization"
                                }
                            }
                        },
                        "description": ""
                    }
                }
            }
        },
        "/api/v1/providers/sandbox-pix/callbacks/": {
            "post": {
                "operationId": "receiveSandboxPixCallback",
                "description": "Verify a provider-style callback and atomically enqueue risk processing.",
                "tags": [
                    "providers"
                ],
                "responses": {
                    "202": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/SandboxCallbackResponse"
                                }
                            }
                        },
                        "description": ""
                    }
                }
            }
        },
        "/api/v1/sandbox/pix/charges/{charge_id}/actions/": {
            "post": {
                "operationId": "controlSandboxPixCharge",
                "description": "Let an authorized tenant exercise deterministic local provider scenarios.",
                "parameters": [
                    {
                        "in": "header",
                        "name": "Authorization",
                        "schema": {
                            "type": "string"
                        },
                        "description": "Bearer organization API key with payments:write.",
                        "required": true
                    },
                    {
                        "in": "path",
                        "name": "charge_id",
                        "schema": {
                            "type": "string",
                            "format": "uuid"
                        },
                        "required": true
                    }
                ],
                "tags": [
                    "sandbox"
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/SandboxControl"
                            }
                        },
                        "application/x-www-form-urlencoded": {
                            "schema": {
                                "$ref": "#/components/schemas/SandboxControl"
                            }
                        },
                        "multipart/form-data": {
                            "schema": {
                                "$ref": "#/components/schemas/SandboxControl"
                            }
                        }
                    },
                    "required": true
                },
                "security": [
                    {
                        "ApiKeyAuth": []
                    }
                ],
                "responses": {
                    "202": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/SandboxCallbackResponse"
                                }
                            }
                        },
                        "description": ""
                    }
                }
            }
        }
    },
    "components": {
        "schemas": {
            "ActionEnum": {
                "enum": [
                    "confirm",
                    "delay",
                    "duplicate"
                ],
                "type": "string",
                "description": "* `confirm` - confirm\n* `delay` - delay\n* `duplicate` - duplicate"
            },
            "Agreement": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "string",
                        "format": "uuid"
                    },
                    "status": {
                        "type": "string"
                    },
                    "customer": {
                        "$ref": "#/components/schemas/MaskedCustomer"
                    },
                    "amount": {
                        "type": "string"
                    },
                    "currency": {
                        "$ref": "#/components/schemas/CurrencyEnum"
                    },
                    "fee_bps": {
                        "type": "integer"
                    },
                    "delivery_window_days": {
                        "type": "integer"
                    },
                    "delivery_due_at": {
                        "type": "string",
                        "format": "date-time",
                        "nullable": true
                    },
                    "inspection_deadline_at": {
                        "type": "string",
                        "format": "date-time",
                        "nullable": true
                    },
                    "refund_reason": {
                        "type": "string",
                        "nullable": true
                    },
                    "realtime_sequence": {
                        "type": "integer",
                        "minimum": 0
                    },
                    "external_customer_id": {
                        "type": "string"
                    }
                },
                "required": [
                    "amount",
                    "currency",
                    "customer",
                    "delivery_due_at",
                    "delivery_window_days",
                    "external_customer_id",
                    "fee_bps",
                    "id",
                    "inspection_deadline_at",
                    "realtime_sequence",
                    "refund_reason",
                    "status"
                ]
            },
            "AgreementCreate": {
                "type": "object",
                "properties": {
                    "external_customer_id": {
                        "type": "string"
                    },
                    "customer": {
                        "$ref": "#/components/schemas/CustomerCreate"
                    },
                    "amount": {
                        "type": "string"
                    },
                    "currency": {
                        "$ref": "#/components/schemas/CurrencyEnum"
                    },
                    "delivery_window_days": {
                        "type": "integer",
                        "maximum": 90,
                        "minimum": 1
                    }
                },
                "required": [
                    "amount",
                    "currency",
                    "customer",
                    "delivery_window_days",
                    "external_customer_id"
                ]
            },
            "AgreementCreationResponse": {
                "type": "object",
                "properties": {
                    "agreement": {
                        "$ref": "#/components/schemas/Agreement"
                    },
                    "checkout_url": {
                        "type": "string",
                        "format": "uri"
                    }
                },
                "required": [
                    "agreement",
                    "checkout_url"
                ]
            },
            "CurrencyEnum": {
                "enum": [
                    "BRL",
                    "USD"
                ],
                "type": "string",
                "description": "* `BRL` - BRL\n* `USD` - USD"
            },
            "CustomerCreate": {
                "type": "object",
                "properties": {
                    "name": {
                        "type": "string"
                    },
                    "email": {
                        "type": "string",
                        "format": "email"
                    },
                    "document": {
                        "type": "string"
                    }
                },
                "required": [
                    "document",
                    "email",
                    "name"
                ]
            },
            "CustomerDeliveryAcceptance": {
                "type": "object",
                "properties": {
                    "challenge_id": {
                        "type": "string",
                        "format": "uuid"
                    },
                    "acceptance_token": {
                        "type": "string"
                    }
                },
                "required": [
                    "acceptance_token",
                    "challenge_id"
                ]
            },
            "CustomerDeliveryAcceptanceResponse": {
                "type": "object",
                "properties": {
                    "status": {
                        "type": "string"
                    },
                    "transfer_id": {
                        "type": "string",
                        "format": "uuid"
                    }
                },
                "required": [
                    "status",
                    "transfer_id"
                ]
            },
            "CustomerOtpRequestResponse": {
                "type": "object",
                "properties": {
                    "challenge_id": {
                        "type": "string",
                        "format": "uuid"
                    },
                    "expires_at": {
                        "type": "string",
                        "format": "date-time"
                    }
                },
                "required": [
                    "challenge_id",
                    "expires_at"
                ]
            },
            "CustomerOtpVerification": {
                "type": "object",
                "properties": {
                    "code": {
                        "type": "string",
                        "maxLength": 6,
                        "minLength": 6
                    }
                },
                "required": [
                    "code"
                ]
            },
            "CustomerOtpVerificationResponse": {
                "type": "object",
                "properties": {
                    "acceptance_token": {
                        "type": "string"
                    }
                },
                "required": [
                    "acceptance_token"
                ]
            },
            "DeliveryReportResponse": {
                "type": "object",
                "properties": {
                    "agreement_id": {
                        "type": "string",
                        "format": "uuid"
                    },
                    "status": {
                        "$ref": "#/components/schemas/DeliveryReportResponseStatusEnum"
                    },
                    "inspection_deadline_at": {
                        "type": "string",
                        "format": "date-time"
                    }
                },
                "required": [
                    "agreement_id",
                    "inspection_deadline_at",
                    "status"
                ]
            },
            "DeliveryReportResponseStatusEnum": {
                "enum": [
                    "INSPECTION"
                ],
                "type": "string",
                "description": "* `INSPECTION` - INSPECTION"
            },
            "IntegrationOrganization": {
                "type": "object",
                "properties": {
                    "organization": {
                        "$ref": "#/components/schemas/OrganizationSummary"
                    }
                },
                "required": [
                    "organization"
                ]
            },
            "MaskedCustomer": {
                "type": "object",
                "properties": {
                    "name": {
                        "type": "string"
                    },
                    "email_masked": {
                        "type": "string"
                    },
                    "document_masked": {
                        "type": "string"
                    }
                },
                "required": [
                    "document_masked",
                    "email_masked",
                    "name"
                ]
            },
            "OrganizationSummary": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "string",
                        "format": "uuid"
                    },
                    "name": {
                        "type": "string"
                    }
                },
                "required": [
                    "id",
                    "name"
                ]
            },
            "PublicAgreement": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "string",
                        "format": "uuid"
                    },
                    "status": {
                        "type": "string"
                    },
                    "customer": {
                        "$ref": "#/components/schemas/MaskedCustomer"
                    },
                    "amount": {
                        "type": "string"
                    },
                    "currency": {
                        "$ref": "#/components/schemas/CurrencyEnum"
                    },
                    "fee_bps": {
                        "type": "integer"
                    },
                    "delivery_window_days": {
                        "type": "integer"
                    },
                    "delivery_due_at": {
                        "type": "string",
                        "format": "date-time",
                        "nullable": true
                    },
                    "inspection_deadline_at": {
                        "type": "string",
                        "format": "date-time",
                        "nullable": true
                    },
                    "refund_reason": {
                        "type": "string",
                        "nullable": true
                    },
                    "realtime_sequence": {
                        "type": "integer",
                        "minimum": 0
                    }
                },
                "required": [
                    "amount",
                    "currency",
                    "customer",
                    "delivery_due_at",
                    "delivery_window_days",
                    "fee_bps",
                    "id",
                    "inspection_deadline_at",
                    "realtime_sequence",
                    "refund_reason",
                    "status"
                ]
            },
            "PublicCheckoutResponse": {
                "type": "object",
                "properties": {
                    "agreement": {
                        "$ref": "#/components/schemas/PublicAgreement"
                    },
                    "payment": {
                        "$ref": "#/components/schemas/PublicPayment"
                    }
                },
                "required": [
                    "agreement"
                ]
            },
            "PublicPayment": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "string",
                        "format": "uuid"
                    },
                    "status": {
                        "$ref": "#/components/schemas/PublicPaymentStatusEnum"
                    },
                    "amount": {
                        "type": "string"
                    },
                    "currency": {
                        "$ref": "#/components/schemas/CurrencyEnum"
                    },
                    "pix_copy_paste": {
                        "type": "string"
                    }
                },
                "required": [
                    "amount",
                    "currency",
                    "id",
                    "pix_copy_paste",
                    "status"
                ]
            },
            "PublicPaymentStatusEnum": {
                "enum": [
                    "PENDING",
                    "CONFIRMED",
                    "REJECTED"
                ],
                "type": "string",
                "description": "* `PENDING` - PENDING\n* `CONFIRMED` - CONFIRMED\n* `REJECTED` - REJECTED"
            },
            "PublicSandboxPixChargeResponse": {
                "type": "object",
                "properties": {
                    "payment": {
                        "$ref": "#/components/schemas/PublicSandboxPixPayment"
                    }
                },
                "required": [
                    "payment"
                ]
            },
            "PublicSandboxPixPayment": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "string",
                        "format": "uuid"
                    },
                    "status": {
                        "$ref": "#/components/schemas/PublicSandboxPixPaymentStatusEnum"
                    },
                    "amount": {
                        "type": "string"
                    },
                    "currency": {
                        "$ref": "#/components/schemas/CurrencyEnum"
                    },
                    "pix_copy_paste": {
                        "type": "string"
                    }
                },
                "required": [
                    "amount",
                    "currency",
                    "id",
                    "pix_copy_paste",
                    "status"
                ]
            },
            "PublicSandboxPixPaymentStatusEnum": {
                "enum": [
                    "PENDING",
                    "CONFIRMED",
                    "REJECTED"
                ],
                "type": "string",
                "description": "* `PENDING` - Pending\n* `CONFIRMED` - Confirmed\n* `REJECTED` - Rejected"
            },
            "SandboxCallbackResponse": {
                "type": "object",
                "properties": {
                    "status": {
                        "type": "string"
                    },
                    "duplicate": {
                        "type": "boolean"
                    }
                },
                "required": [
                    "duplicate",
                    "status"
                ]
            },
            "SandboxControl": {
                "type": "object",
                "properties": {
                    "action": {
                        "$ref": "#/components/schemas/ActionEnum"
                    }
                },
                "required": [
                    "action"
                ]
            }
        },
        "securitySchemes": {
            "ApiKeyAuth": {
                "type": "http",
                "scheme": "bearer",
                "bearerFormat": "escrow API key"
            }
        }
    }
}