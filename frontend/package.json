{
  "name": "escrow-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "tsc -b && vite build",
    "dev": "vite --host 0.0.0.0",
    "api:generate": "mkdir -p src/lib/generated && uv run --project .. python ../manage.py spectacular --format openapi-json --file src/lib/generated/openapi.json && bunx openapi-typescript src/lib/generated/openapi.json -o src/lib/generated/openapi.ts",
    "lint": "biome check .",
    "test": "bun test",
    "test:e2e": "playwright test",
    "typecheck": "tsc -b --pretty false"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "vite": "^7.1.7"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.4",
    "@playwright/test": "1.57.0",
    "@testing-library/jest-dom": "^6.8.3",
    "@testing-library/react": "^16.3.0",
    "@types/bun": "^1.3.14",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "happy-dom": "^18.0.1",
    "openapi-typescript": "7.10.1",
    "typescript": "^5.9.2"
  }
}
